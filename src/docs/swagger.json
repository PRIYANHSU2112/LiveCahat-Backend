          }
        }
      }
    },
    "/coin-packs/{id}/toggle": {
      "patch": {
        "summary": "Toggle Coin Pack status (Admin)",
        "tags": [
          "Coin Packs"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Coin pack activated/deactivated successfully"
          }
        }
      }
    },
    "/payments/create-order": {
      "post": {
        "summary": "Create a Coin Pack Purchase Order",
        "tags": ["Payments"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["coinPackId"],
                "properties": {
                  "coinPackId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Payment order created successfully" }
        }
      }
    },
    "/payments/webhook-mock": {
      "post": {
        "summary": "Mock Razorpay Webhook (Testing Only)",
        "tags": ["Payments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
